graph TD
  Internet["Internet"]
  HostingerDNS["Hostinger DNS (domínio: pigbit.site)"]
  ContaboVPS["VPS Contabo (IP público)"]
  Nginx["Nginx (proxy reverso)"]
  API["Container API (Nest.js)"]
  Worker["Container Worker (processador de filas)"]
  Postgres["Postgres DB"]
  Redis["Redis (fila / cache)"]
  MinIO["Armazenamento - S3/MinIO"]
  CI["Runner CI/CD (GitHub Actions / Runner)"]
  Payments["NowPayments (gateway)"]

  Internet --> HostingerDNS
  HostingerDNS -->|aponta para IP| ContaboVPS
  ContaboVPS --> Nginx
  Nginx --> API
