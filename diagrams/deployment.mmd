  API --> Postgres
  API --> Redis
  Worker --> Postgres
  Worker --> Redis
  API --> MinIO
  API --> Payments
  CI -->|deploy via SSH| ContaboVPS

  classDef infra fill:#f3f4f6,stroke:#333
