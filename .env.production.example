# Exemplo de .env para produção (pigbit-api)
# Copie para .env e edite com as variáveis reais

# Base
NODE_ENV=production
PORT=3000
DB_SYNC=false

# Database
DATABASE_URL=postgresql://pigbit:senha_segura@postgres:5432/pigbit

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=sua_chave_jwt_super_segura_aqui_minimo_32_caracteres

# Nowpayments (integração crypto)
NOWPAYMENTS_API_KEY=sua_chave_nowpayments
NOWPAYMENTS_API_ENDPOINT=https://api.nowpayments.io/v1

# Email
SMTP_HOST=smtp.seu-email.com
SMTP_PORT=587
SMTP_USER=seu-email@seu-dominio.com
SMTP_PASS=sua_senha_ou_app_password
SMTP_FROM=noreply@pigbit.com

# URLs
API_URL=https://api.pigbit.com
FRONTEND_URL=https://pigbit.com

# Logging
LOG_LEVEL=info
